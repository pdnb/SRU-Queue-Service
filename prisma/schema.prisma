generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  STAFF
}

enum TicketStatus {
  WAITING
  CALLED
  SERVING
  COMPLETED
  SKIPPED
  NO_SHOW
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  counterId String?  @unique
  counter   Counter? @relation(fields: [counterId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String        @id @default(cuid())
  name        String
  prefix      String
  description String?
  isActive    Boolean       @default(true)
  counters    Counter[]
  tickets     QueueTicket[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Counter {
  id        String        @id @default(cuid())
  name      String
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isActive  Boolean       @default(true)
  staff     User?
  tickets   QueueTicket[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model QueueTicket {
  id          String       @id @default(cuid())
  number      Int
  displayNo   String
  studentId       String
  studentName     String
  studentPicture  String?
  serviceId       String
  service     Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  counterId   String?
  counter     Counter?     @relation(fields: [counterId], references: [id], onDelete: SetNull)
  status      TicketStatus @default(WAITING)
  queueDate   DateTime
  createdAt   DateTime     @default(now())
  calledAt    DateTime?
  completedAt DateTime?

  @@index([studentId, serviceId, queueDate])
  @@index([serviceId, queueDate, status])
}
