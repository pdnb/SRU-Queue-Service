generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  STAFF
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  DISABLED
}

enum TicketStatus {
  WAITING
  CALLED
  SERVING
  COMPLETED
  SKIPPED
  NO_SHOW
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String?
  status    UserStatus @default(ACTIVE)
  role      Role
  counterId String?    @unique
  counter   Counter?   @relation(fields: [counterId], references: [id], onDelete: SetNull)
  accounts  Account[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Service {
  id          String        @id @default(cuid())
  name        String
  prefix      String
  description String?
  isActive    Boolean       @default(true)
  counters    Counter[]
  tickets     QueueTicket[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Counter {
  id        String        @id @default(cuid())
  name      String
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isActive  Boolean       @default(true)
  staff     User?
  tickets   QueueTicket[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model QueueTicket {
  id          String       @id @default(cuid())
  number      Int
  displayNo   String
  studentId       String
  studentName     String
  studentPicture  String?
  serviceId       String
  service     Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  counterId   String?
  counter     Counter?     @relation(fields: [counterId], references: [id], onDelete: SetNull)
  status      TicketStatus @default(WAITING)
  queueDate   DateTime
  createdAt   DateTime     @default(now())
  calledAt    DateTime?
  completedAt DateTime?

  @@index([studentId, serviceId, queueDate])
  @@index([serviceId, queueDate, status])
}
