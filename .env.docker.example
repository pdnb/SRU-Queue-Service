# Copy to .env before: docker compose up --build
# cp .env.docker.example .env

# MariaDB (docker-compose db service)
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=queue_service
MARIADB_USER=queue
MARIADB_PASSWORD=queuepassword

# App
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
AUTH_SECRET=change-me-to-a-random-secret-in-production
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth0 SSO (optional)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
SSO_ALLOWED_EMAIL_DOMAIN=

# Set true on first deploy to load demo users/services, then set back to false
RUN_DB_SEED=true

# SIS
SIS_MOCK=true
SIS_API_URL=
SIS_API_KEY=

# Pusher (optional)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
