# Database
# Local dev (SQLite)
DATABASE_URL="file:./dev.db"

# Production (TiDB / MySQL) — required on Vercel (SQLite is not supported serverless)
# DATABASE_URL="mysql://USER:PASSWORD@tidb-host.example:4000/queue_service?sslaccept=strict"

# Auth.js (credentials login)
AUTH_SECRET="change-me-to-a-random-secret-in-production"

# Auth0 SSO (optional — credentials login still works without these)
APP_BASE_URL="http://localhost:3000"
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
# 64-char random string: openssl rand -hex 32
AUTH0_SECRET=""
SSO_ALLOWED_EMAIL_DOMAIN="university.ac.th"

# Per-environment base URL (e.g. https://queue-service.vercel.app)
AUTH_URL=""

# SIS API (set SIS_MOCK=true for local development)
SIS_MOCK=true
SIS_API_URL=""
SIS_API_KEY=""

# Pusher (optional — falls back to polling when not configured)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Public app URL for QR codes (set to your Vercel URL, e.g. https://queue-service.vercel.app)
NEXT_PUBLIC_APP_URL=""
